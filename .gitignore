# Local training checkpoints and model weights (do not version in this logs repo)
# Note: .gitignore cannot filter by file size, so we ignore common weight extensions.
results/metrics/lightweight_optimization/**/*.pth
results/metrics/lightweight_optimization/**/*.pt
results/metrics/lightweight_optimization/**/*.ckpt
results/metrics/lightweight_optimization/**/*.bin
results/metrics/lightweight_optimization/**/*.safetensors
